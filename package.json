{
  "name": "@bounded-systems/verbspec",
  "version": "0.3.0",
  "description": "Spec-driven CLI core: author a verb once as a typed VerbSpec, project it to CLI, MCP, OpenAPI, and Anthropic tool surfaces",
  "bounded": {
    "tagline": "Spec-driven CLI core: author a verb once as a typed VerbSpec, project it to CLI, MCP, OpenAPI, and Anthropic tool surfaces",
    "kind": "guest"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bounded-systems/verbspec.git"
  },
  "homepage": "https://github.com/bounded-systems/verbspec#readme",
  "bugs": {
    "url": "https://github.com/bounded-systems/verbspec/issues"
  },
  "keywords": [
    "verbspec",
    "cli",
    "zod",
    "json-schema",
    "mcp",
    "openapi",
    "anthropic-tools",
    "spec-driven"
  ],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "zod": "^3.25.0 || ^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  }
}
